}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
@media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}*{animation:none!important;transition:none!important}}
body{font-family:'Jost',sans-serif;background:var(--black);color:var(--cream);line-height:1.65;font-size:17px}
h1,h2,h3{font-family:'Bodoni Moda',serif;line-height:1.15;color:var(--cream)}
a{color:inherit}
img{max-width:100%}
.wrap{max-width:1080px;margin:0 auto;padding:0 24px}
.eyebrow{font-size:12px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:var(--gold)}
.btn{display:inline-block;padding:16px 32px;border-radius:2px;font-weight:600;text-decoration:none;font-size:16px;transition:transform .15s ease,box-shadow .15s ease}
.btn:focus-visible{outline:3px solid var(--gold);outline-offset:3px}
.btn-gold{background:var(--gold);color:var(--black)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,168,76,.35)}
.btn-outline{border:1.5px solid var(--gold);color:var(--gold)}
.btn-outline:hover{background:rgba(201,168,76,.12)}
.btn-green{background:var(--emerald);color:var(--cream);border:1px solid rgba(201,168,76,.35)}
.btn-green:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(27,67,50,.5)}

/* NAV */
nav{position:sticky;top:0;z-index:50;background:rgba(10,10,10,.92);backdrop-filter:blur(8px);border-bottom:1px solid rgba(201,168,76,.25)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;max-width:1080px;margin:0 auto}
.logo{font-family:'Bodoni Moda',serif;font-weight:700;font-size:20px;color:var(--cream);text-decoration:none;letter-spacing:.02em}
.logo span{color:var(--gold)}
.nav-links{display:flex;gap:28px;align-items:center}
.nav-links a{color:var(--cream);text-decoration:none;font-size:14px;font-weight:500;opacity:.85}
.nav-links a:hover{opacity:1;color:var(--gold)}
.nav-cta{background:var(--gold);color:var(--black)!important;padding:10px 20px;border-radius:2px;opacity:1!important;font-weight:600}
@media(max-width:760px){.nav-links a:not(.nav-cta){display:none}}

/* HERO */
.hero{background:radial-gradient(ellipse at 20% 0%,var(--emerald-deep),var(--black) 60%);color:var(--cream);padding:96px 0 0;overflow:hidden}
.hero-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:48px;align-items:center;padding-bottom:72px}
.hero h1{color:var(--cream);font-size:clamp(40px,6vw,64px);font-weight:600;margin:20px 0 24px}
.hero h1 em{font-style:italic;color:var(--gold)}
.hero p.lede{font-size:19px;opacity:.88;max-width:520px;margin-bottom:36px}
.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}
.route{position:relative;padding:32px;border:1px solid rgba(201,168,76,.3);border-radius:2px}
.route-line{display:flex;align-items:center;gap:12px;margin-bottom:28px}
.route-dot{width:10px;height:10px;border-radius:50%;background:var(--gold);flex-shrink:0}
.route-path{flex:1;height:1px;background:linear-gradient(90deg,var(--gold),rgba(201,168,76,.2));position:relative}
.route-path::after{content:"✈";position:absolute;left:0;top:-11px;color:var(--gold);font-size:14px;animation:fly 6s ease-in-out infinite}
@keyframes fly{0%{left:0;opacity:0}8%{opacity:1}46%{left:calc(100% - 14px);opacity:1}54%{opacity:0}100%{left:calc(100% - 14px);opacity:0}}
@media (prefers-reduced-motion:reduce){.route-path::after{animation:none;left:auto;right:-4px;opacity:1}}
.route-cities{display:flex;justify-content:space-between;font-size:13px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold-soft);margin-bottom:24px}
.route-stat{border-top:1px solid rgba(201,168,76,.2);padding:14px 0 0;margin-top:14px}
.route-stat b{font-family:'Bodoni Moda',serif;font-size:26px;color:var(--gold);display:block}
.route-stat span{font-size:13px;opacity:.75}
